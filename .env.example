# Server
PORT=3000

# S3-compatible storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Basescan/Etherscan API
ETHERSCAN_API_KEY=

# x402 / payments
WALLET_PRIVATE_KEY=

# Coinbase Developer Platform (CDP) — required for Base Mainnet facilitator
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Public base URL for skill URLs
BASE_URL=http://localhost:3000

# AI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
