# Server
PORT=3000

# S3-compatible storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

# Basescan/Etherscan API
ETHERSCAN_API_KEY=

# x402 / payments
WALLET_PRIVATE_KEY=

# Public base URL for skill URLs
BASE_URL=http://localhost:3000

# AI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# x402 Bazaar (optional, default: https://bazaar.x402.org)
BAZAAR_URL=
